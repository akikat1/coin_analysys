# Binance Futures API ключи
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here

# Сеть: true = testnet (безопасно), false = mainnet (реальные деньги!)
TESTNET=true

# Кредитное плечо
LEVERAGE=10
MAX_LEVERAGE=20         # авто-снижение при высоком ATR не превысит этого
MIN_LEVERAGE=3          # минимальное авто-плечо при экстремальной волатильности

# Управление рисками
MAX_RISK_PER_TRADE_PCT=0.01   # 1% баланса на сделку
MAX_DAILY_LOSS_PCT=0.05       # 5% дневной стоп-лосс
MAX_DRAWDOWN_PCT=0.15         # 15% максимальная просадка
MIN_BALANCE_USD=150           # minimum balance with minNotional safety
MARKET_CONTEXT_REFRESH_SEC=30 # обновление OI/L-S контекста (сек)
ALLOW_RANGE_TRADING=false     # true: разрешить сделки в боковике
RANGE_SIZE_MULTIPLIER=0.35    # размер в боковике (если ALLOW_RANGE_TRADING=true)

# Чувствительность сигналов
MIN_CONFIDENCE=72
MIN_RR=2.0
MIN_VOLUME_RATIO=1.2
ENFORCE_VOLUME_FILTER=true
ADX_TREND_THRESHOLD=25
ADX_WEAK_TREND_THRESHOLD=20
SIGNAL_COOLDOWN_SEC=300
MAX_TRADES_PER_DAY=10
AVOID_HOURS_UTC=2-5       # UTC windows to skip entries, format: "2-5,13-14"
MAX_MICROSTRUCTURE_STALENESS_MS=2000
MAX_SPREAD_PCT=0.0005
HTF_FILTER_ENABLED=true

# BNB скидка на комиссию
BNB_DISCOUNT=false

# Limit order entry
USE_LIMIT_ORDER=true          # true = лимитный вход (дешевле), false = рыночный
LIMIT_ORDER_OFFSET_PCT=0.0002 # насколько "глубже" от цены выставлять лимит (0.02%)
LIMIT_ORDER_TIMEOUT_SEC=8     # через сколько секунд переключиться на market

# Trailing stop
TRAILING_STOP_ENABLED=true
TRAILING_ATR_MULTIPLIER=1.2   # стоп будет на ATR*1.2 ниже/выше текущей цены

# Telegram уведомления
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# Telegram команды (те же ключи, команды включаются автоматически)
TELEGRAM_COMMANDS_ENABLED=true

# Live smoke-test (микросделка при старте live)
LIVE_SMOKE_TEST_ON_START=false
LIVE_SMOKE_MAX_WAIT_SEC=30
LIVE_SMOKE_HOLD_SEC=20
LIVE_SMOKE_NOTIONAL_USDT=6
# Для безопасности по умолчанию запрещено на mainnet
LIVE_SMOKE_ALLOW_MAINNET=false

# AI advisor (optional, OpenAI-compatible or Gemini API)
AI_ENABLED=false
AI_MODE=hybrid
AI_PROVIDER=auto
AI_PROVIDER_PRIORITY=gemini,groq,openai
AI_AUTO_FALLBACK=true
AI_MAX_CANDIDATES=24
AI_CONTINUE_ON_BLOCK=true
AI_BLOCK_POLICY=consensus
AI_BLOCK_REQUIRED=2
AI_MAX_SUCCESS_OPINIONS=3
AI_API_KEY=
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini
AI_TIMEOUT_SEC=10
AI_MAX_SCORE_ADJUST=8
AI_MIN_BASE_SCORE=58
AI_MIN_CALL_INTERVAL_SEC=2
AI_FAIL_OPEN=true
AI_BACKTEST_ENABLED=false

# Gemini pool (first provider by default priority)
AI_GEMINI_BASE_URL=https://generativelanguage.googleapis.com
AI_GEMINI_API_KEYS=gemini_key_1,gemini_key_2
AI_GEMINI_MODELS=gemini-2.0-flash,gemini-2.0-flash-lite,gemini-1.5-pro

# Groq pool (OpenAI-compatible endpoint)
AI_GROQ_BASE_URL=https://api.groq.com/openai/v1
AI_GROQ_API_KEYS=groq_key_1,groq_key_2
AI_GROQ_MODELS=llama-3.3-70b-versatile,llama-3.1-8b-instant

# OpenAI pool
AI_OPENAI_BASE_URL=https://api.openai.com/v1
AI_OPENAI_API_KEYS=openai_key_1,openai_key_2
AI_OPENAI_MODELS=gpt-4o-mini,gpt-4.1-mini
ATR_PCT_HIGH_VOLATILITY=0.8
MAX_POSITION_DURATION_SEC=14400
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5
DEADMAN_SWITCH_SEC=15
